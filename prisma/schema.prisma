generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model JumpRequest {
  id              String   @id @default(cuid())
  travelerName    String
  mission         String
  birthYear       Int      @default(1990)
  destinationYear      Int
  plutoniumCores       Int
  suppressParadoxCheck Boolean  @default(false)
  createdAt            DateTime @default(now())
}
