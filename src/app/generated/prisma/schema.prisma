generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model JumpRequest {
  id              String   @id @default(cuid())
  travelerName    String
  mission         String
  destinationYear Int
  plutoniumCores  Int
  createdAt       DateTime @default(now())
}
